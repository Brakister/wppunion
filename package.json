    "next":                    "14.2.3",
    "pino":                    "^9.2.0",
    "qrcode":                  "^1.5.3",
    "react":                   "^18.3.0",
    "react-dom":               "^18.3.0",
    "socket.io":               "^4.7.5",
    "socket.io-client":        "^4.7.5"
  },
  "devDependencies": {
    "@types/bcrypt":      "^5.0.2",
    "@types/jsonwebtoken":"^9.0.6",
    "@types/node":        "^20.12.5",
    "@types/react":       "^18.3.0",
    "@types/react-dom":   "^18.3.0",
